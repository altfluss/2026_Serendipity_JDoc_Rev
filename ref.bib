@article{Wang20192678,
  author                 = {Wang, Chang-Dong and Deng, Zhi-Hong and Lai, Jian-Huang and Yu, Philip S.},
  title                  = {Serendipitous recommendation in e-commerce using innovator-based collaborative filtering},
  year                   = {2019},
  journal                = {IEEE Transactions on Cybernetics},
  volume                 = {49},
  number                 = {7},
  pages                  = {2678-2692},
  doi                    = {10.1109/TCYB.2018.2841924},
  affiliations           = {School of Data and Computer Science, Sun Yat-sen University, Guangzhou, 510006, China; Department of Computer Science, University of Illinois at Chicago, Chicago, 60607, IL, United States; Institute for Data Science, Tsinghua University, Beijing, 100084, China},
  abstract               = {Collaborative filtering (CF) algorithms have been widely used to build recommender systems since they have distinguishing capability of sharing collective wisdoms and experiences. However, they may easily fall into the trap of the Matthew effect, which tends to recommend popular items and hence less popular items become increasingly less popular. Under this circumstance, most of the items in the recommendation list are already familiar to users and therefore the performance would seriously degenerate in finding cold items, i.e., new items and niche items. To address this issue, in this paper, a user survey is first conducted on the online shopping habits in China, based on which a novel recommendation algorithm termed innovator-based CF is proposed that can recommend cold items to users by introducing the concept of innovators. Specifically, innovators are a special subset of users who can discover cold items without the help of recommender system. Therefore, cold items can be captured in the recommendation list via innovators, achieving the balance between serendipity and accuracy. To confirm the effectiveness of our algorithm, extensive experiments are conducted on the dataset provided by Alibaba Group in Ali Mobile Recommendation Algorithm Competition, which is collected from the real e-commerce environment and covers massive user behavior log data. © 2013 IEEE.},
  author_keywords        = {Cold items; Collaborative filtering (CF); Innovators; Recommender system; Serendipity},
  keywords               = {Behavioral research; Cybernetics; Electronic mail; Electronic mail filters; Interactive computer systems; Mobile commerce; Real time systems; Recommender systems; Sorting; Cold items; Collaboration; innovators; serendipity; Technological innovation; Collaborative filtering},
  correspondence_address = {J.-H. Lai; School of Data and Computer Science, Sun Yat-sen University, Guangzhou, 510006, China; email: stsljh@mail.sysu.edu.cn},
  publisher              = {Institute of Electrical and Electronics Engineers Inc.},
  issn                   = {21682267},
  pmid                   = {29994495},
  language               = {English},
  abbrev_source_title    = {IEEE Trans. Cybern.},
  type                   = {Article},
  publication_stage      = {Final},
  source                 = {Scopus}
}

